Allow from all

<IfModule mod_headers.c>
    # CORS — cache subdomain serves static files cross-origin to the main domain
    Header always set Access-Control-Allow-Origin "*"
</IfModule>

# bez tohoto nefunguje kořenová url na wedosu
RewriteEngine On

<IfModule mod_mime.c>
    AddType application/json .json
</IfModule>

<IfModule mod_expires.c>
    # cache 1 rok — hashovaná jména souborů (aktivity-2026-<hash>.json apod.) jsou content-addressed
    ExpiresActive On
    ExpiresDefault A31557600
</IfModule>

# Manifest nesmí být cachovaný — obsahuje aktuální hashe, na kterých závisí všechny ostatní soubory
<FilesMatch "^manifest-\d+\.json$">
    <IfModule mod_headers.c>
        Header always set Cache-Control "no-store, max-age=0"
        Header unset Expires
        Header unset ETag
    </IfModule>
    FileETag None
</FilesMatch>
