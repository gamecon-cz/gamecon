  <div id="stavUlozeni" class="success">Všechny změny uloženy</div>
  <form method="post" style="position: relative">
    <input style="position:absolute;top:-45px;right:2px;visibility:hidden" id="horniSubmit" type="submit" value="Uložit změny" />
    <table id="editacniTabulka"><tr><td>
