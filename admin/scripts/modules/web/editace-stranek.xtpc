<?php
  class EditacestranekTpl {
    public $context = array();
    public $dependencies = array("");
    protected $buffer = array();
    protected $current = "";        // currently buffered block
    
    function editaceStranek() {
      if($this->current == "editaceStranek") {
        if(@$this->buffer["editaceStranek"]) {
          $out = $this->buffer["editaceStranek"] . ob_get_clean();
          $this->buffer["editaceStranek"] = "";
        } else {
          $out = ob_get_clean();
        }
        $this->current = "";
        return $out;
      } else {
        $out = @$this->buffer["editaceStranek"];
        $this->buffer["editaceStranek"] = "";
        return $out;
      }
    }

    function parse_editaceStranek() {
      if($this->current != "editaceStranek") {
        if($this->current) @$this->buffer[$this->current] .= ob_get_clean();
        ob_start();
        $this->current = "editaceStranek";
      }
