  <script src="files/showdown.js"></script>
  <script src="files/jquery.autosize.js"></script>
  <script>
    function ukazObsah(){
      var md=new Showdown.converter();
      var html=md.makeHtml($('#obsahStranky').val());
      html=html.replace(/src=\"\/files/g,'src="<?=@$this->context["URL_WEBU"]?>/files');
      $('#nahled').html(html);
    }
    var ulozeno=true;
    ukazObsah();
    $('#obsahStranky').autosize();
    $('#obsahStranky').keyup(function(){
      ukazObsah();
      if(ulozeno) {
        $('#stavUlozeni').removeClass();
        $('#stavUlozeni').addClass('error');
        $('#stavUlozeni').html('Neuložené změny!');
        $('#horniSubmit').css('visibility','visible');
      }
    });
  </script><?php
