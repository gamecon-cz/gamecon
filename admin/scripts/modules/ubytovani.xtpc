    function ubytovani_ubytovani() {
      if($this->current == "ubytovani_ubytovani") {
        if(@$this->buffer["ubytovani_ubytovani"]) {
          $out = $this->buffer["ubytovani_ubytovani"] . ob_get_clean();
          $this->buffer["ubytovani_ubytovani"] = "";
        } else {
          $out = ob_get_clean();
        }
        $this->current = "";
        return $out;
      } else {
        $out = @$this->buffer["ubytovani_ubytovani"];
        $this->buffer["ubytovani_ubytovani"] = "";
        return $out;
      }
    }

    function parse_ubytovani_ubytovani() {
      if($this->current != "ubytovani_ubytovani") {
        if($this->current) @$this->buffer[$this->current] .= ob_get_clean();
        ob_start();
        $this->current = "ubytovani_ubytovani";
      }
      ?>
  Standardně povolujeme pouze změnu ubytování ze spacáku na postel nebo jiný „upgrade“ (v opačném případě by postel zůstala volná a reálně by ji tak platil GameCon). Odhlášení z ubytování umožňujeme nejpozději den předem, pokud člověk např. nečekaně musí odjet. Odhlášení neděle povolujeme (člověk se často splete).<br><br>
  <form method="post">
    <?=@$this->context["shop"]->ubytovaniHtml()?><br>
    <input type="submit" name="zpracujUbytovani" value="Uložit">
  </form>
  <?php
    }
  
