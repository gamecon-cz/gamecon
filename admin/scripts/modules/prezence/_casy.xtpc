        if($this->current) @$this->buffer[$this->current] .= ob_get_clean();
        ob_start();
        $this->current = "casy_cas";
      }
      ?><option <?=@$this->context["sel"]?> value="<?=@$this->context["val"]?>"><?=@$this->context["cas"]?></option><?php
    }
  
  }
  