table { border-collapse: collapse; }
td, th { border: solid 0.3mm #000000; padding: 1mm 1mm; }
.hlavicka { text-align: left; }
.hlavicka .info { font-weight: normal; }
.hlavicka .nazev { font-size: 150%; max-width: 110mm; }
