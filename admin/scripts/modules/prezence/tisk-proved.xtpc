body > div:nth-child(6n+5) { height: 50mm; border-bottom: dashed 1px #888; margin-bottom: 5mm; width: 280mm; }
body > div:nth-child(6n+0) { page-break-after: always; }
</style>
<style media="print">
body { margin: 0; }
body > div:nth-child(6n+5) { display: none; height: 0; border: none; margin: 0; }
</style>

<?=$this->aktivity_aktivita()?>

