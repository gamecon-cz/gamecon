<?php
  class TiskTpl {
    public $context = array();
    public $dependencies = array("");
    protected $buffer = array();
    protected $current = "";        // currently buffered block
    
    function tisk() {
      if($this->current == "tisk") {
        if(@$this->buffer["tisk"]) {
          $out = $this->buffer["tisk"] . ob_get_clean();
          $this->buffer["tisk"] = "";
        } else {
          $out = ob_get_clean();
        }
        $this->current = "";
        return $out;
      } else {
        $out = @$this->buffer["tisk"];
        $this->buffer["tisk"] = "";
        return $out;
      }
    }

    function parse_tisk() {
      if($this->current != "tisk") {
        if($this->current) @$this->buffer[$this->current] .= ob_get_clean();
        ob_start();
        $this->current = "tisk";
      }
      ?>

<div><?=@$this->context["casy"]?></div>

<h2>Tisk prezenčních listů</h2>

<?=$this->tisk_aktivity()?>

<?=$this->tisk_zadneAktivity()?>

<?=$this->tisk_nevybrano()?>

<?php
    }
  
