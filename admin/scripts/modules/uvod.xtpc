        if(@$this->buffer["uvod_potvrditZruseniPrace"]) {
          $out = $this->buffer["uvod_potvrditZruseniPrace"] . ob_get_clean();
          $this->buffer["uvod_potvrditZruseniPrace"] = "";
        } else {
          $out = ob_get_clean();
        }
        $this->current = "";
        return $out;
      } else {
        $out = @$this->buffer["uvod_potvrditZruseniPrace"];
        $this->buffer["uvod_potvrditZruseniPrace"] = "";
        return $out;
      }
    }

    function parse_uvod_potvrditZruseniPrace() {
      if($this->current != "uvod_potvrditZruseniPrace") {
        if($this->current) @$this->buffer[$this->current] .= ob_get_clean();
        ob_start();
        $this->current = "uvod_potvrditZruseniPrace";
      }
      ?>
<script>
$('#zrusit').submit(function(){
  return confirm('Uživatel nedostal materiály nebo má záporný zůstatek. Ukončit práci s uživatelem?');
});
</script>
<?php
    }
  
  }
  