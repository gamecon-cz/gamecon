<?php
  class UvodTpl {
    public $context = array();
    public $dependencies = array("");
    protected $buffer = array();
    protected $current = "";        // currently buffered block
    
    function uvod() {
      if($this->current == "uvod") {
        if(@$this->buffer["uvod"]) {
          $out = $this->buffer["uvod"] . ob_get_clean();
          $this->buffer["uvod"] = "";
        } else {
          $out = ob_get_clean();
        }
        $this->current = "";
        return $out;
      } else {
        $out = @$this->buffer["uvod"];
        $this->buffer["uvod"] = "";
        return $out;
      }
    }

    function parse_uvod() {
      if($this->current != "uvod") {
        if($this->current) @$this->buffer[$this->current] .= ob_get_clean();
        ob_start();
        $this->current = "uvod";
      }
      ?>

