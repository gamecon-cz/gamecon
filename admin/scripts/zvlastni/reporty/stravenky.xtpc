<?php
  class StravenkyTpl {
    public $context = array();
    public $dependencies = array("");
    protected $buffer = array();
    protected $current = "";        // currently buffered block
    
    function stravenky() {
      if($this->current == "stravenky") {
        if(@$this->buffer["stravenky"]) {
          $out = $this->buffer["stravenky"] . ob_get_clean();
          $this->buffer["stravenky"] = "";
        } else {
          $out = ob_get_clean();
        }
        $this->current = "";
        return $out;
      } else {
        $out = @$this->buffer["stravenky"];
        $this->buffer["stravenky"] = "";
        return $out;
      }
    }

    function parse_stravenky() {
      if($this->current != "stravenky") {
        if($this->current) @$this->buffer[$this->current] .= ob_get_clean();
        ob_start();
        $this->current = "stravenky";
      }
      ?>
<style>

.radek { border: solid 0.3mm; page-break-inside: avoid; display: inline-block; font-family: sans-serif; border-left: none; }
.radek > div { float: left; width: 16mm; height: 16mm; padding: 2mm; border-left: solid 0.3mm; overflow: hidden; position: relative; }
.radek > hr { margin: 0; border: 0; clear: both; height: 0; }
.jidlo > img { width: 100%; position: absolute; top: 0; left: 0; opacity: 0.5; }

</style>

<?=$this->stravenky_uzivatel()?>


<?php
    }
  
