        $this->buffer["stravenky_uzivatel"] = "";
        return $out;
      }
    }

    function parse_stravenky_uzivatel() {
      if($this->current != "stravenky_uzivatel") {
        if($this->current) @$this->buffer[$this->current] .= ob_get_clean();
        ob_start();
        $this->current = "stravenky_uzivatel";
      }
      ?>
<div class="radek">
  <div><?=@$this->context["login_uzivatele"]?> (<?=@$this->context["id_uzivatele"]?>)</div>
  <?=$this->stravenky_uzivatel_jidlo()?>
  <hr>
</div><br>
<?php
    }
  
