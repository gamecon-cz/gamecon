# Static archive of gamecon.cz 2010 (reconstructed from the Internet
# Archive). The live DB-driven router and database are lost; this serves the
# captured 2010 pages as flat HTML and maps the original pretty URLs onto
# them. Theme/images live under /system_styly, /lightbox.
#
# Content pages were restored from web.archive.org (see
# README-archive-2010.md), the latest capture per URL within the 2010 site
# lifetime (2010-01..2011-04). Unmapped URLs return a real HTTP 404 + the
# themed 404 page (Stranka nebyla archivovana) rather than silently showing
# News, so genuinely uncaptured links read as honestly dead.

DirectoryIndex index.html
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Never rewrite real files (assets) or directories.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Asset-type requests 404 naturally rather than serving HTML.
    RewriteRule \.(ico|css|js|jpg|jpeg|gif|png|pdf|svg|woff2?|ttf)$ - [L]

    # Homepage / news -> the captured 2010 front page.
    RewriteRule ^$              index.html [L]
    RewriteRule ^novinky/?$     index.html [L]

    # Pages restored from the Internet Archive (pretty URL -> static file).
    RewriteRule ^anketa\-2009/?$  anketa-2009.html [L]
    RewriteRule ^anketa\-2010/?$  anketa-2010.html [L]
    RewriteRule ^bonusove\-hry/sobotni\-party/?$  bonusove-hry/sobotni-party.html [L]
    RewriteRule ^bonusove\-hry/tartas\-\-\-sermirske\-vystoupeni/?$  bonusove-hry/tartas---sermirske-vystoupeni.html [L]
