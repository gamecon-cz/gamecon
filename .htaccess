# Static archive of GameCon 2006 (reconstructed from the Internet Archive).
#
# The 2006 festival ran 13.-16. 7. 2006 in OLOMOUC (DDM, tř. 17. listopadu 47 +
# nearby university dorms) — the venue moved to Pardubice only from 2007. It
# was still run by the Altar publishing house; the website lived at
# gamecon.altar.cz (a different host and CMS from the 2009+ gamecon.cz site).
# This serves the captured flat .html pages as-is. Pages were restored from
# web.archive.org, transcoded ISO-8859-2 -> UTF-8, with gamecon.altar.cz
# absolute links rewritten to root-relative.
#
# The 2006 pages reference no internal .php endpoints (only external links), so
# no .php redirects are needed. Uncaptured URLs -> themed 404.

DirectoryIndex index.html
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve real files / dirs directly (links are flat bare filenames).
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Homepage.
    RewriteRule ^$  index.html [L]

    # Everything else (uncaptured) -> themed 404.
    RewriteRule ^.*$ - [R=404,L]
</IfModule>
