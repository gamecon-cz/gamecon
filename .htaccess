# Static archive of gamecon.cz 2011 (reconstructed from the Internet
# Archive). The live DB-driven router and database (dbgacon) are lost; this
# serves the captured pages as flat HTML and maps the original pretty URLs
# onto them. Theme/images live under /system_styly, /lightbox, /galerie.
#
# Content pages were restored from web.archive.org (see
# README-archive-2011.md). Captures that were themselves the News front page
# (URLs the 2011 site already served News for) are intentionally NOT mapped,
# so they fall through to the themed 404 below rather than misleadingly
# showing News. Unmapped URLs return a real HTTP 404 + the themed 404 page.

DirectoryIndex index.html
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Never rewrite real files (assets) or directories.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Asset-type requests 404 naturally rather than serving HTML.
    RewriteRule \.(ico|css|js|jpg|jpeg|gif|png|pdf|svg|woff2?|ttf)$ - [L]

    # Homepage / news -> the captured front page.
    RewriteRule ^$              index.html [L]
    RewriteRule ^novinky/?$     index.html [L]

    # Hand-cleaned pages present since the initial reconstruction.
    RewriteRule ^gamecon/o-gameconu/?$            gamecon/o-gameconu.html [L]
    RewriteRule ^organizatori/organizacni-tym/?$  organizatori/organizacni-tym.html [L]
    RewriteRule ^kontakt/?$                       kontakt.html [L]

    # Pages restored from the Internet Archive (pretty URL -> static file).
    RewriteRule ^anketa\-2011/?$  anketa-2011.html [L]
    RewriteRule ^bonusove\-hry/hon\-na\-rudy\-rijen/?$  bonusove-hry/hon-na-rudy-rijen.html [L]
    RewriteRule ^bonusove\-hry/mixer/?$  bonusove-hry/mixer.html [L]
    RewriteRule ^bonusove\-hry/spina/?$  bonusove-hry/spina.html [L]
    RewriteRule ^bonusy/gamecon\-bonusy/?$  bonusy/gamecon-bonusy.html [L]
    RewriteRule ^bonusy/spina\-2010/?$  bonusy/spina-2010.html [L]
    RewriteRule ^deskove\-hry/arkham\-horror/?$  deskove-hry/arkham-horror.html [L]
    RewriteRule ^deskove\-hry/armada\-game/?$  deskove-hry/armada-game.html [L]
    RewriteRule ^deskove\-hry/bang\-/?$  deskove-hry/bang-.html [L]
