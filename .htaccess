    RewriteRule ^organizatori/jak\-se\-stat\-organizatorem/?$  organizatori/jak-se-stat-organizatorem.html [L]
    RewriteRule ^organizatori/organizacni\-tym/?$  organizatori/organizacni-tym.html [L]
