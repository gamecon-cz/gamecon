# Static archive of GameCon 2008 (reconstructed from the Internet Archive).
#
# The 2008 festival ran 10.-13. 7. 2008 in Pardubice and was still run by the
# Altar publishing house; its website lived at gamecon.altar.cz (a different
# host and a completely different CMS/theme from the 2009+ gamecon.cz site).
# This serves the captured flat .html pages as-is. Pages were restored from
# web.archive.org, transcoded ISO-8859-2 -> UTF-8, with gamecon.altar.cz
# absolute links rewritten to root-relative.
#
# Dynamic .php endpoints (registration form, guestbook, questionnaires, live
# participant/team lists) had no backend to capture and are intentionally not
# served -> they fall through to the themed 404. Where a static snapshot of a
# .php page's content survived (prihlaska3, seznam_druzin, seznam_prihlasenych),
# the .php URL is redirected to that .html snapshot so the menu links resolve.

DirectoryIndex index.html
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
    RewriteEngine On

    # .php links that have a captured .html snapshot -> redirect to it, so
    # the (ubiquitous) menu links don't 404. prihlaska.php was the dynamic
    # registration entry; send it to the captured registration-info page.
    # Targets are root-relative (leading /): an [R] redirect with a
    # relative target would otherwise be resolved against the filesystem
    # DocumentRoot and produce a bogus /var/www/.../x.html Location.
    RewriteRule ^prihlaska\.php$            /prihlaska2.html [R=301,L]
    RewriteRule ^prihlaska3\.php$           /prihlaska3.html [R=301,L]
    RewriteRule ^seznam_druzin\.php$        /seznam_druzin.html [R=301,L]
    RewriteRule ^seznam_prihlasenych\.php$  /seznam_prihlasenych.html [R=301,L]

    # Serve real files / dirs directly (links are flat bare filenames).
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Homepage.
    RewriteRule ^$  index.html [L]

    # Everything else (uncaptured dynamic .php, missing pages) -> themed 404.
    RewriteRule ^.*$ - [R=404,L]
</IfModule>
