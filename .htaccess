RewriteEngine on

# Archive 2019: base image DocumentRoot is the project root → rewrite into web/.
# The original 2019-era top-level .htaccess was "Deny from all" (Wedos vhost
# pointed straight at web/). Use the web/ rewrite so the Docker docroot works.
RewriteRule .* web/$0 [L]

RewriteRule .* - [F,L]
