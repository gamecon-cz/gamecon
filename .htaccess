# Static archive of gamecon.cz 2009 (reconstructed from the Internet
# Archive). The live DB-driven router and database are lost; this serves the
# captured pages as flat HTML and maps the original pretty URLs onto them.
# Theme/images live under /system_styly and /lightbox.
#
# Content pages were restored from web.archive.org (see README-archive-2009.md).
# GameCon 2009 was held 16.-19. 7. 2009 at the University of Pardubice campus.
# Uncaptured URLs (forum threads, gallery photos, download PDFs, dynamic .php
# pages) return a real HTTP 404 + the themed 404 page.

DirectoryIndex index.html
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
    RewriteEngine On

    # /forum exists as a real directory (would hold the uncaptured forum
    # threads), so the -d short-circuit below would serve the bare dir and
    # Apache would 403 it (no DirectoryIndex inside). Map this landing URL to
    # the captured forum front page first, before the -d rule can claim it.
    RewriteRule ^forum/?$    forum.html [L]

    # Never rewrite real files (assets) or directories.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Asset-type requests 404 naturally rather than serving HTML.
    RewriteRule \.(ico|css|js|jpg|jpeg|gif|png|pdf|svg|woff2?|ttf)$ - [L]

    # Homepage / news -> the captured front page.
    RewriteRule ^$           index.html [L]
    RewriteRule ^novinky/?$  novinky.html [L]

    # "Pánové Jeskyně" had no page of its own on the live 2009 site - the menu
    # links it but it 302-redirected to the PJové (Dungeon Masters) listing.
    # Reproduce that redirect instead of 404ing. Target is the captured page.
    RewriteRule ^mistrovstvi\-v\-drd/panove\-jeskyne/?$  /organizatori/pjove [R=301,L]

    # Pages restored from the Internet Archive (pretty URL -> static file).
    RewriteRule ^anketa\-2009/?$  anketa-2009.html [L]
    RewriteRule ^deskove\-hry/bang/?$  deskove-hry/bang.html [L]
    RewriteRule ^deskove\-hry/carcassonne/?$  deskove-hry/carcassonne.html [L]
    RewriteRule ^deskove\-hry/ceny\-pro\-viteze\-turnaju/?$  deskove-hry/ceny-pro-viteze-turnaju.html [L]
    RewriteRule ^deskove\-hry/galaxy\-trucker/?$  deskove-hry/galaxy-trucker.html [L]
    RewriteRule ^deskove\-hry/heckmeck/?$  deskove-hry/heckmeck.html [L]
    RewriteRule ^deskove\-hry/jantaris/?$  deskove-hry/jantaris.html [L]
    RewriteRule ^deskove\-hry/legie/?$  deskove-hry/legie.html [L]
    RewriteRule ^deskove\-hry/non\-stop\-herna/?$  deskove-hry/non-stop-herna.html [L]
    RewriteRule ^deskove\-hry/o\-deskovych\-hrach\-na\-gc/?$  deskove-hry/o-deskovych-hrach-na-gc.html [L]
    RewriteRule ^deskove\-hry/osadnici\-z\-katanu/?$  deskove-hry/osadnici-z-katanu.html [L]
    RewriteRule ^deskove\-hry/prehled\-deskovych\-her\-na\-gc2009/?$  deskove-hry/prehled-deskovych-her-na-gc2009.html [L]
    RewriteRule ^deskove\-hry/proroctvi\-\-\-mistrovstvi\-cr/?$  deskove-hry/proroctvi---mistrovstvi-cr.html [L]
    RewriteRule ^deskove\-hry/proroctvi/?$  deskove-hry/proroctvi.html [L]
    RewriteRule ^deskove\-hry/theby/?$  deskove-hry/theby.html [L]
    RewriteRule ^deskove\-hry/zelvi\-zavody/?$  deskove-hry/zelvi-zavody.html [L]
    RewriteRule ^dilny/archiv\-dilny\-2008/?$  dilny/archiv-dilny-2008.html [L]
