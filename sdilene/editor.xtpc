          $('#nahled<?=@$this->context["fields"]?><?=@$this->context["id_akce"]?>').html(html);
        }
        ukazObsah();
        $('#popisek<?=@$this->context["fields"]?><?=@$this->context["id_akce"]?>').autosize();
        $('#popisek<?=@$this->context["fields"]?><?=@$this->context["id_akce"]?>').keyup(function(){
          ukazObsah();
        });
