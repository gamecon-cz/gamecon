<?php
  class EditorTpl {
    public $context = array();
    public $dependencies = array("");
    protected $buffer = array();
    protected $current = "";        // currently buffered block
    
    function upravy() {
      if($this->current == "upravy") {
        if(@$this->buffer["upravy"]) {
          $out = $this->buffer["upravy"] . ob_get_clean();
          $this->buffer["upravy"] = "";
        } else {
          $out = ob_get_clean();
        }
        $this->current = "";
        return $out;
      } else {
        $out = @$this->buffer["upravy"];
        $this->buffer["upravy"] = "";
        return $out;
      }
    }

    function parse_upravy() {
      if($this->current != "upravy") {
        if($this->current) @$this->buffer[$this->current] .= ob_get_clean();
        ob_start();
        $this->current = "upravy";
      }
      ?><script type="text/javascript">
function overeni()
{
  err=0;
  msg='';
  if(!$('[name="<?=@$this->context["fields"]?>[url_akce]"]').val())
  { err=1; msg+="\n• Je třeba vyplnit url."; }
  if($('[name="<?=@$this->context["fields"]?>[url_akce]"]').val().search(/^[a-z0-9\-]*$/)==-1)
  { err=1; msg+="\n• URL smí obsahovat jenom malá písmena bez diakritiky, číslice a pomlčky."; }
  
  if(err)
  {
    alert('Nepodařilo se uložit, protože:'+msg); 
    return false;
  }
  else
    return true;
}
$(function(){
  $('[name="<?=@$this->context["fields"]?>Odesilatko"]').click(function(){
    if(!overeni()) return false;
    odesilatko=$(this);
    odesilatko.attr('disabled','disabled');
    $.post(document.URL,$(this).closest('form').serialize()+'&<?=@$this->context["ajaxKlic"]?>=true',function(data){
      if(data.chyby.length>0)
      {
        alert(data.chyby.join("\n&bull;"));
        odesilatko.removeAttr('disabled');
      }
      else
      {
        odesilatko.closest('form').submit();
      }
    }, "json");
    return false;
  });
});
</script>

